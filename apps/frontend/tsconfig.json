{
	"extends": "@interview-lab/typescript-config/base.json",
	"compilerOptions": {
		/* Language and Environment - 언어 및 환경 (Next.js 최적화) */
		"target": "ES2017", // Next.js 권장 타겟 (브라우저 호환성)
		"lib": [
			"DOM",
			"DOM.Iterable",
			"ES2017"
		], // DOM API + ES2017 기능
		"jsx": "react-jsx", // React 17+ 새로운 JSX transform

		/* Module System - 모듈 시스템 */
		"module": "esnext", // 최신 ES 모듈 사용
		"moduleResolution": "bundler", // Next.js/Webpack 번들러 해석 방식
		"allowJs": true, // JavaScript 파일 허용 (.js 파일도 import 가능)
		"paths": {
			"@/*": [
				"./src/*"
			] // 경로 별칭 설정
		},

		/* Emit - 빌드 출력 */
		"noEmit": true, // TypeScript는 타입 체크만, Next.js가 컴파일 담당
		"incremental": true, // 증분 컴파일로 빌드 속도 향상

		/* Next.js - Next.js 전용 */
		"plugins": [
			{
				"name": "next" // Next.js TypeScript 플러그인
			}
		]
	},
	"include": [
		"next-env.d.ts", // Next.js 환경 타입 정의
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts", // Next.js 생성 타입
		".next/dev/types/**/*.ts", // Next.js dev 타입
		"**/*.mts"
	],
	"exclude": [
		"node_modules" // base.json의 exclude(.next 포함)를 오버라이드
	]
}
