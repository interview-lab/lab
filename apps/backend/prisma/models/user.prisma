model User {
  id Int @id @default(autoincrement())

  email    String  @unique
  username String  @unique
  password String?

  profileImage String?
  level        Int

  googleId String? @unique
  githubId String? @unique

  sessions  Session[]
  bookmarks Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
