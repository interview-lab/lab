model Session {
  id     String @id @default(cuid())
  userId Int?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  category  Category?
  questions Question[]

  totalScore Int?
  status     SessionStatus
  aiFeedback String?

  createdAt DateTime  @default(now())
  endedAt   DateTime?
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
