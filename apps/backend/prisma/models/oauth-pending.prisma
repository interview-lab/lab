model OAuthPendingRegistration {
  id            Int          @id @default(autoincrement())
  provider      AuthProvider
  providerId    String
  tempToken     String       @unique
  providerEmail String?
  providerName  String?
  profileImage  String?
  expiresAt     DateTime
  createdAt     DateTime     @default(now())

  @@unique([provider, providerId])
}
