model Answer {
  id         String   @id @default(cuid())
  questionId String   @unique
  question   Question @relation(fields: [questionId], references: [id])
  session   Session @relation(fields: [sessionId], references: [id])
  sessionId String

  content String

  score      Int?
  tip        String?
  aiFeedback String?

  createdAt DateTime @default(now())
}
