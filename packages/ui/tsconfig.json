{
	"extends": "@interview-lab/typescript-config/base.json",
	"compilerOptions": {
		"rootDir": ".",
		"baseUrl": "./src",
		"paths": {
			"~/*": [
				"./src/*"
			]
		},
		/* Language and Environment*/
		"lib": [
			"DOM",
			"DOM.Iterable",
			"ES2022"
		], // base의 ["ES2022"]에 DOM API 추가
		"types": [
			"node",
			"vite/client"
		], // Vite 환경 타입 정의 포함

		/* Module System */
		"module": "ES2022",
		"moduleResolution": "bundler",

		/* JSX - React 컴포넌트 지원 */
		"jsx": "react-jsx",

		"noEmit": true // .js 파일 생성 안 함
	},
	"include": [
		"**/*"
	] // 모든 TypeScript 파일 포함
}
